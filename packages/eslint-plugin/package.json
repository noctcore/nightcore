{
  "name": "@nightcore/eslint-plugin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.61.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@typescript-eslint/rule-tester": "^8.61.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  }
}
