{
  "name": "nightcore",
  "version": "0.0.0",
  "private": true,
  "description": "Nightcore — an autonomous Claude dev studio: Rust + Tauri core over a Bun provider sidecar.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc -b",
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "desktop": "bun run --filter @nightcore/desktop dev",
    "web": "bun run --filter @nightcore/web dev",
    "web:build": "bun run --filter @nightcore/web build",
    "sidecar": "bun run apps/sidecar/src/index.ts",
    "cli": "bun run apps/cli/src/index.ts",
    "tui": "bun run apps/tui/src/index.ts",
    "new:tool": "bun run tools/codegen/new-tool.ts",
    "test": "bun test",
    "test:rust": "bun run --filter @nightcore/desktop test",
    "test:all": "bun test && bun run test:rust",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
