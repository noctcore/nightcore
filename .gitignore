node_modules/
dist/
dist-tsc/
*.tsbuildinfo

# Storybook build output
storybook-static/

# Vitest browser-mode failure screenshots
**/__screenshots__/

# Rust / Tauri build output + generated files
target/
apps/desktop/src-tauri/gen/
# Generated icons are reproducible from icons/source.png via `tauri icon`
apps/desktop/src-tauri/icons/android/
apps/desktop/src-tauri/icons/ios/
# Compiled sidecar (Tauri externalBin) — a build artifact, reproduced by
# `bun run --filter @nightcore/sidecar compile`
apps/desktop/src-tauri/binaries/
# Stray ts-rs dump from bare `cargo test` (no TS_RS_EXPORT_DIR). The canonical
# bindings live in apps/web/src/lib/generated/; this dir is wrong-config (bigint) noise.
apps/desktop/src-tauri/bindings/

# Nightcore local state (per-project runtime state stays ignored). The exception is
# the structure-lock manifest, which is dogfooded by the published portable
# @noctcore/harness runner in CI (structure-lock.yml), so it MUST be tracked. Ignore
# the dir's CONTENTS (not the dir itself) so the negation can re-include the file.
.nightcore/*
!.nightcore/harness.json

# Logs
*.log
logs/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Env
.env
.env.local
.env.*.local

design
