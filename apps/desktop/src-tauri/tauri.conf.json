{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nightcore",
  "version": "0.0.0",
  "identifier": "dev.shirone.nightcore",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run --filter @nightcore/web dev",
    "beforeBuildCommand": "bun run --filter @nightcore/web build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nightcore",
        "url": "index.html",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "© 2026 Shirone",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
